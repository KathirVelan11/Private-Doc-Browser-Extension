{
  "manifest_version": 3,
  "name": "Private Doc — Local AI Assistant",
  "version": "1.0.0",
  "description": "Select text, right-click, and ask a fully-local AI (Ollama) grounded in your own documents and bookmarks. Nothing leaves your machine.",
  "permissions": ["contextMenus", "sidePanel", "storage", "bookmarks"],
  "host_permissions": ["http://127.0.0.1:5000/*", "http://localhost:5000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Private Doc assistant"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
